OPENAI_API_KEY=sk-...

# Single WLED target (used if ARTNET_NODES is not set)
ARTNET_IP=192.168.178.102
LED_COUNT=100

# Multiple WLED targets — comma-separated ip:led_count pairs.
# When set, ARTNET_IP and LED_COUNT are ignored.
# ARTNET_NODES=192.168.178.102:100,192.168.178.114:60

# Physical strip layout — comma-separated LED count per lamp/strip.
# Must sum to LED_COUNT (or total across ARTNET_NODES). Leave empty for one flat strip.
# STRIP_LAYOUT=25,25,25,25
